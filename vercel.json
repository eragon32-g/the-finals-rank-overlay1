{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/layout-editor",
      "destination": "/404.html"
    },
    {
      "source": "/layout-editor.html",
      "destination": "/404.html"
    }
  ]
}